@{
    /**/

    ViewBag.Title = "Attendance Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="page-header">
    <div>
        <div class="page-title">Attendance Register</div>
        <div class="page-sub">Generate monthly attendance report in PDF or Excel</div>
    </div>
</div>
@if (TempData["Error"] != null)
{
    <div style="background:#7f1d1d33;border:1px solid #b91c1c;border-radius:8px;
                padding:12px 16px;margin-bottom:20px;color:#fca5a5;font-size:13px;">
        &#9888;&nbsp;@TempData["Error"]
    </div>
}
<!-- ── Filter Card ────────────────────────────────────────────────────────── -->
<div class="card" style="max-width:640px;">
    <div class="card-header">
        <div class="card-title">Select Period</div>
        <div class="card-sub">Choose the date range for the attendance register</div>
    </div>
    <div class="card-body">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;">
            <div class="form-group">
                <label class="form-label">From Date</label>
                <input type="date" id="fromDate" class="form-ctrl"
                       value="@ViewBag.FromDate" />
            </div>
            <div class="form-group">
                <label class="form-label">To Date</label>
                <input type="date" id="toDate" class="form-ctrl"
                       value="@ViewBag.ToDate" />
            </div>
        </div>
        <!-- Quick select buttons -->
        <div style="margin-bottom:20px;">
            <label class="form-label">Quick Select</label>
            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:6px;">
                <button type="button" class="btn btn-ghost btn-sm" onclick="setMonth(0)">This Month</button>
                <button type="button" class="btn btn-ghost btn-sm" onclick="setMonth(-1)">Last Month</button>
                <button type="button" class="btn btn-ghost btn-sm" onclick="setMonth(-2)">2 Months Ago</button>
                <button type="button" class="btn btn-ghost btn-sm" onclick="setMonth(-3)">3 Months Ago</button>
            </div>
        </div>
        <!-- Download buttons -->
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
            @if (User.IsInRole("Admin") || User.IsInRole("HRManager"))
            {
                <button type="button" class="btn btn-primary" onclick="download('pdf')">
                    &#128196;&nbsp;Download PDF
                </button>
                <button type="button" class="btn btn-success" onclick="download('excel')">
                    &#128202;&nbsp;Download Excel
                </button>
            }
            else
            {
                <div style="color:var(--muted);font-size:13px;padding:10px 0;">
                    &#128274;&nbsp;Report download requires Admin or HR Manager role.
                </div>
            }
        </div>
    </div>
</div>
<!-- ── Report Preview Info ────────────────────────────────────────────────── -->
<div class="card" style="max-width:640px;margin-top:16px;
     border-color:rgba(91,110,245,0.25);background:rgba(91,110,245,0.04);">
    <div class="card-body" style="display:flex;gap:14px;align-items:flex-start;padding:18px 20px;">
        <div style="font-size:22px;margin-top:2px;">&#128161;</div>
        <div>
            <div style="font-weight:600;font-size:14px;margin-bottom:8px;">
                Report Contents
            </div>
            <div style="color:var(--muted);font-size:13px;line-height:1.8;">
                The attendance register includes:
                <ul style="margin:6px 0 0 16px;padding:0;">
                    <li>Company header and report period</li>
                    <li>Employee ID and full name</li>
                    <li>Day columns 1–31 with punch In / Out times</li>
                    <li>
                        <span class="mono" style="color:var(--accent);font-size:12px;">AA</span> = Authorised Absence &nbsp;|&nbsp;
                        <span class="mono" style="color:var(--accent);font-size:12px;">00</span> = Absent &nbsp;|&nbsp;
                        <span class="mono" style="color:var(--accent);font-size:12px;">HH</span> = Holiday
                    </li>
                    <li>Total Work Days per employee</li>
                    <li>Page number and print date</li>
                </ul>
            </div>
        </div>
    </div>
</div>
<!-- ── NuGet Reminder ─────────────────────────────────────────────────────── -->
<div class="card" style="max-width:640px;margin-top:16px;
     border-color:rgba(245,158,66,0.25);background:rgba(245,158,66,0.04);">
    <div class="card-body" style="padding:16px 20px;">
        <div style="font-size:12px;font-weight:600;text-transform:uppercase;
                    letter-spacing:.5px;color:#f59e42;margin-bottom:10px;">
            &#9888;&nbsp; Required NuGet Packages
        </div>
        <div style="font-size:12px;color:var(--muted);line-height:1.8;">
            Run in Package Manager Console (Default project = HRMS.Infrastructure):
            <pre style="background:var(--bg);border-radius:6px;padding:10px 14px;
                        margin-top:8px;font-size:11px;color:var(--accent2);
                        overflow-x:auto;">Install-Package iTextSharp -Version 5.5.13.3
Install-Package ClosedXML -Version 0.102.2</pre>
        </div>
    </div>
</div>
@section scripts {
    <script>
(function () {

    function setMonth(offset) {
        var d    = new Date();
        var year = d.getFullYear();
        var mon  = d.getMonth() + offset;   // JS months 0-based

        // Normalise across year boundaries
        while (mon < 0)  { mon += 12; year--; }
        while (mon > 11) { mon -= 12; year++; }

        var firstDay = new Date(year, mon, 1);
        var lastDay  = new Date(year, mon + 1, 0);   // day 0 = last day of prev month

        document.getElementById('fromDate').value = fmt(firstDay);
        document.getElementById('toDate').value   = fmt(lastDay);
    }

    function fmt(date) {
        var y  = date.getFullYear();
        var m  = String(date.getMonth() + 1).padStart(2, '0');
        var d  = String(date.getDate()).padStart(2, '0');
        return y + '-' + m + '-' + d;
    }

    function download(type) {
        var from = document.getElementById('fromDate').value;
        var to   = document.getElementById('toDate').value;

        if (!from || !to) {
            alert('Please select both From and To dates.');
            return;
        }
        if (from > to) {
            alert('From date cannot be after To date.');
            return;
        }

        var action = type === 'pdf' ? 'DownloadPdf' : 'DownloadExcel';
        var url    = '@Url.Action("Index", "Attendance")'.replace('Index', action)
                   + '?from=' + from + '&to=' + to;

        window.location.href = url;
    }

    // Expose to inline onclick
    window.setMonth   = setMonth;
    window.download   = download;

}());
    </script>
}
