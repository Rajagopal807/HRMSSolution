@model HRMS.Application.DTOs.ApplyLeaveScreenDto
@{
    ViewBag.Title = "Apply for Leave";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Safe defaults for re-display after validation failure
    string fromVal = (Model.Form != null && Model.Form.FromDate > System.DateTime.MinValue)
        ? Model.Form.FromDate.ToString("yyyy-MM-dd")
        : System.DateTime.Today.ToString("yyyy-MM-dd");

    string toVal = (Model.Form != null && Model.Form.ToDate > System.DateTime.MinValue)
        ? Model.Form.ToDate.ToString("yyyy-MM-dd")
        : System.DateTime.Today.ToString("yyyy-MM-dd");

    string selectedEmpId = Model.Form != null ? Model.Form.EmployeeId ?? "" : "";
    string selectedLtId = Model.Form != null ? Model.Form.LeaveTypeMasterId ?? "" : "";
    string selectedSession = Model.Form != null ? Model.Form.Session ?? "FullDay" : "FullDay";
    string selectedReason = Model.Form != null ? Model.Form.Reason ?? "" : "";
    var isEdit = Model.Form.ApplicationId > 0;
}

<style>
    .session-group {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .session-pill {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 18px;
        border-radius: 8px;
        border: 1.5px solid var(--border);
        cursor: pointer;
        font-size: 13.5px;
        color: var(--text);
        transition: all .15s;
        user-select: none;
    }

        .session-pill:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        .session-pill input {
            accent-color: var(--accent);
            cursor: pointer;
        }

        .session-pill.active {
            border-color: var(--accent);
            background: rgba(91,110,245,.09);
            color: var(--accent);
        }

    .emp-preview {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 14px 16px;
        display: none;
        gap: 12px;
        align-items: center;
        margin-top: 10px;
    }

        .emp-preview.show {
            display: flex;
        }

    .ep-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(91,110,245,.18);
        color: var(--accent);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        font-weight: 700;
        flex-shrink: 0;
    }

    .halfday-notice {
        display: none;
        background: rgba(245,158,66,.08);
        border: 1px solid rgba(245,158,66,.3);
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 12px;
        color: #f59e42;
        margin-top: 8px;
    }

        .halfday-notice.show {
            display: block;
        }

    .day-count {
        display: inline-block;
        padding: 4px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-family: 'DM Mono',monospace;
        font-weight: 600;
        background: rgba(52,211,153,.12);
        color: var(--accent2);
        border: 1px solid rgba(52,211,153,.25);
        margin-top: 8px;
    }
</style>

<div style="margin-bottom:20px;">
    <a href="@Url.Action("Index")" class="btn btn-ghost btn-sm">&#8592;&nbsp;Back</a>
</div>

<div class="page-header">
    <div>
        <div class="page-title">Apply for Leave</div>
        <div class="page-sub">Submit a new leave application</div>
    </div>
</div>

@using (Html.BeginForm(isEdit ? "Edit" : "Apply", "LeaveApplication", FormMethod.Post, new { id = "applyForm" }))
{
    @Html.AntiForgeryToken()

    @Html.HiddenFor(m => m.Form.ApplicationId)

    if (!ViewData.ModelState.IsValid)
    {
        <div id="errordisplay" class="rpt-err-box">
            <strong>Please fix the following:</strong>
            @Html.ValidationSummary(true, "",
                               new { style = "margin:6px 0 0;padding-left:16px;" })
        </div>
    }

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;
                max-width:900px;align-items:start;">

        <!-- ── Left ──────────────────────────────────────────────────────── -->
        <div style="display:flex;flex-direction:column;gap:16px;">

            <!-- Employee selection -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title">Employee</div>
                    <div class="card-sub">Select the employee applying for leave</div>
                </div>
                <div class="card-body">

                    <!-- Search box (drives datalist) -->
                    <div class="form-group">
                        <label class="form-label">Employee ID / Name *</label>
                        <input type="text" id="empCodeSearch" class="form-ctrl"
                               list="empList"
                               placeholder="Type employee ID or name..."
                               autocomplete="off" />
                        @Html.HiddenFor(m => m.Form.EmployeeId, new { id = "hiddenEmployeeId" })
                        @Html.ValidationMessageFor(m => m.Form.EmployeeId, "",
                                                          new { @class = "err-label" })
                    </div>

                    <!-- Datalist for quick lookup -->
                    <datalist id="empList">
                        @foreach (var emplist in Model.Employees)
                        {
                            <option value="@($"{emplist.EmployeeId} - {emplist.EmployeeName}")"
                                    data-id="@emplist.EmployeeId"
                                    data-name="@emplist.EmployeeName"
                                    data-dept="@emplist.DepartmentName"
                                    data-code="@emplist.EmployeeId"></option>
                        }
                    </datalist>

                    <!-- Employee preview card -->
                    <div class="emp-preview" id="empPreview">
                        <div class="ep-avatar" id="epAvatar"></div>
                        <div>
                            <div style="font-weight:600;font-size:14px;" id="epName"></div>
                            <div style="font-size:12px;color:var(--muted);margin-top:2px;"
                                 id="epMeta"></div>
                        </div>
                    </div>

                    <!-- Fallback dropdown -->
                    <div style="margin-top:12px;">
                        <label class="form-label" style="font-size:10px;">Or select from list</label>
                        <select id="empDropdown" class="form-ctrl">
                            <option value="">-- Select Employee --</option>
                            @foreach (var emp in Model.Employees)
                            {
                                <option value="@emp.EmployeeId"
                                        data-code="@emp.EmployeeId"
                                        data-name="@emp.EmployeeName"
                                        data-dept="@emp.DepartmentName"
                                        @(emp.EmployeeId == selectedEmpId ? "selected" : "")>
                                    @($"{emp.EmployeeId} - {@emp.EmployeeName}")
                                    @*@emp.EmployeeId : @emp.EmployeeName (@emp.DepartmentName)*@
                                </option>
                            }
                        </select>
                    </div>

                </div>
            </div>

            <!-- Leave Type -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title">Leave Type *</div>
                    <div class="card-sub">Select from active leave types</div>
                </div>
                <div class="card-body">
                    <select name="Form.LeaveTypeMasterId" id="leaveTypeId"
                            class="form-ctrl" onchange="onLeaveTypeChange(this)">
                        <option value="">-- Select Leave Type --</option>
                        @foreach (var lt in Model.LeaveTypes)
                        {
                            <option value="@lt.LeavetypeID"
                                    data-halfday="@lt.AllowHalfDay.ToString().ToLower()"
                                    data-max="@lt.MaxDaysPerYear"
                                    data-name="@lt.Name"
                                    @(lt.LeavetypeID == selectedLtId ? "selected" : "")>
                                @($"{lt.LeavetypeID} - {lt.Name}")
                                @(lt.MaxDaysPerYear > 0 ? $"(max {lt.MaxDaysPerYear} days/yr)" : "")
                            </option>
                        }
                    </select>
                    @Html.ValidationMessage("Form.LeaveTypeMasterId", "",
                                       new { @class = "err-label" })

                    <div id="ltInfo" style="display:none;margin-top:10px;padding:10px 14px;
                         background:rgba(91,110,245,.06);border:1px solid rgba(91,110,245,.2);
                         border-radius:8px;font-size:12px;color:var(--muted);">
                        <span id="ltInfoText"></span>
                    </div>
                </div>
            </div>

        </div>

        <!-- ── Right ─────────────────────────────────────────────────────── -->
        <div style="display:flex;flex-direction:column;gap:16px;">

            <!-- Period + Session -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title">Leave Period *</div>
                    <div class="card-sub">Select date range and session</div>
                </div>
                <div class="card-body">

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
                        <div class="form-group">
                            <label class="form-label">From Date *</label>
                            @Html.TextBox("Form.FromDate", fromVal,
                                               new
                                               {
                                                   @class = "form-ctrl",
                                                   type = "date",
                                                   id = "fromDate",
                                                   onchange = "recalcDays()"
                                               })
                            @Html.ValidationMessage("Form.FromDate", "",
                                               new { @class = "err-label" })
                        </div>
                        <div class="form-group">
                            <label class="form-label">To Date *</label>
                            @Html.TextBox("Form.ToDate", toVal,
                                               new
                                               {
                                                   @class = "form-ctrl",
                                                   type = "date",
                                                   id = "toDate",
                                                   onchange = "recalcDays()"
                                               })
                            @Html.ValidationMessage("Form.ToDate", "",
                                               new { @class = "err-label" })
                        </div>
                    </div>

                    <div id="dayCount" class="day-count" style="display:none;"></div>

                    <!-- Session -->
                    <div style="margin-top:16px;">
                        <label class="form-label">Session *</label>
                        <div class="session-group" id="sessionGroup">
                            <label class="session-pill @(selectedSession == "FullDay" ? "active" : "")"
                                   id="pill-full">
                                <input type="radio" name="Form.Session" value="FullDay"
                                       @(selectedSession == "FullDay" ? "checked" : "")
                                       onchange="onSessionChange(this)" />
                                &#11835;&nbsp;Full Day
                            </label>
                            <label class="session-pill @(selectedSession == "FirstHalf" ? "active" : "")"
                                   id="pill-first" style="opacity:.5;pointer-events:none;">
                                <input type="radio" name="Form.Session" value="FirstHalf"
                                       @(selectedSession == "FirstHalf" ? "checked" : "")
                                       onchange="onSessionChange(this)" />
                                &#9728;&nbsp;First Half
                            </label>
                            <label class="session-pill @(selectedSession == "SecondHalf" ? "active" : "")"
                                   id="pill-second" style="opacity:.5;pointer-events:none;">
                                <input type="radio" name="Form.Session" value="SecondHalf"
                                       @(selectedSession == "SecondHalf" ? "checked" : "")
                                       onchange="onSessionChange(this)" />
                                &#9790;&nbsp;Second Half
                            </label>
                        </div>

                        <div class="halfday-notice" id="halfdayNotice"></div>
                        @Html.ValidationMessage("Form.Session", "",
                                           new { @class = "err-label" })
                    </div>

                </div>
            </div>

            <!-- Reason -->
            @*<div class="card">
                <div class="card-header">
                    <div class="card-title">Reason *</div>
                </div>
                <div class="card-body">
                    @Html.TextArea("Form.Reason", selectedReason,
                                       new
                                       {
                                           @class = "form-ctrl",
                                           rows = "4",
                                           placeholder = "Briefly describe the reason for leave..."
                                       })
                    @Html.ValidationMessage("Form.Reason", "",
                                       new { @class = "err-label" })
                </div>
            </div>*@

            <!-- Submit -->
            <div style="display:flex;gap:10px;">
                <button type="submit" class="btn btn-primary" style="flex:1;">
                    &#10003;&nbsp;@(isEdit ? "Update Leave" : "Apply Leave")
                </button>
                <a href="@Url.Action("Index")" class="btn btn-ghost">Cancel</a>
            </div>

        </div>
    </div>
}

@section scripts {
    <script>
(function () {
    var isInitialLoad = true;
    // ── Build employee lookup map (string keys — EmployeeId is a string) ───────
    var empMap = {};
    var empSearchMap = {};
    @foreach (var e in Model.Employees)
    {
        <text>empMap['@e.EmployeeId'] = {
            id:   '@e.EmployeeId',
            name: '@Html.Raw(e.EmployeeName.Replace("'", "\\'"))',
            dept: '@Html.Raw(e.DepartmentName.Replace("'", "\\'"))'
        };
        empSearchMap['@e.EmployeeId'.toLowerCase()] = '@e.EmployeeId';
        empSearchMap['@Html.Raw((e.EmployeeId + " - " + e.EmployeeName).Replace("'", "\\'").ToLower())'] = '@e.EmployeeId';</text>
    }

    // ── Build leave type half-day flag map (string keys) ──────────────────────
    var ltMap = {};
    @foreach (var lt in Model.LeaveTypes)
    {
        <text>ltMap['@lt.LeavetypeID'] = {
            allowHalfDay: @lt.AllowHalfDay.ToString().ToLower(),
            max:  @lt.MaxDaysPerYear,
            name: '@Html.Raw(lt.Name.Replace("'", "\\'"))'
        };</text>
    }

    var currentAllowHalfDay = false;

    var empCodeSearch  = document.getElementById('empCodeSearch');
    var hiddenEmpId    = document.getElementById('hiddenEmployeeId');
    var empDropdown    = document.getElementById('empDropdown');
    var empPreview     = document.getElementById('empPreview');

    // ── Employee dropdown → update hidden field + preview ─────────────────────
    empDropdown.addEventListener('change', function () {
        selectEmployee(this.value);
    });

    // ── Employee search box (datalist) → update hidden field + dropdown ────────
    empCodeSearch.addEventListener('keydown', function (evt) {
        if (evt.key !== 'Enter') return;

        evt.preventDefault();
        var normalized = normalizeEmployeeSearch(this.value);
        this.value = normalized.displayValue;

        if (normalized.employeeId) {
            selectEmployee(normalized.employeeId);
        } else {
            hiddenEmpId.value = normalized.rawId || '';
            empPreview.classList.remove('show');
        }
    });

    empCodeSearch.addEventListener('change', function () {
        var normalized = normalizeEmployeeSearch(this.value);
        if (normalized.employeeId) {
            selectEmployee(normalized.employeeId);
        }
    });

    empCodeSearch.addEventListener('input', function () {
        var normalized = normalizeEmployeeSearch(this.value, true);
        if (normalized.employeeId) {
            selectEmployee(normalized.employeeId);
        } else {
            hiddenEmpId.value = '';
            empDropdown.value = '';
            empPreview.classList.remove('show');
        }
    });

    function selectEmployee(id) {
        var emp = empMap[id];
        hiddenEmpId.value = id;
        empCodeSearch.value = emp ? emp.id + ' - ' + emp.name : id;
        empDropdown.value = id;
        if (!emp) {
            empPreview.classList.remove('show');
            return;
        }
        var initials = emp.name.split(' ')
            .slice(0, 2).map(function (w) { return w[0] || ''; }).join('');
        document.getElementById('epAvatar').textContent = initials;
        document.getElementById('epName').textContent   = emp.name;
        document.getElementById('epMeta').textContent   = emp.id + ' \u00b7 ' + emp.dept;
        empPreview.classList.add('show');
    }

    function normalizeEmployeeSearch(value, keepTyping) {
        var raw = (value || '').trim();
        var key = raw.toLowerCase();
        var id = empSearchMap[key] || '';
        var rawId = '';

        if (!id && empMap[raw]) {
            id = raw;
        }

        if (!id && /^\d+$/.test(raw)) {
            rawId = raw.length < 11 ? raw.padStart(11, '0') : raw;
            id = empMap[rawId] ? rawId : '';
        }

        if (!id && !keepTyping) {
            var matches = Object.keys(empMap).filter(function (empId) {
                var emp = empMap[empId];
                return empId.toLowerCase().indexOf(key) >= 0
                    || emp.name.toLowerCase().indexOf(key) >= 0;
            });
            if (matches.length === 1) id = matches[0];
        }

        return {
            employeeId: id,
            rawId: rawId,
            displayValue: id && empMap[id] ? empMap[id].id + ' - ' + empMap[id].name : (rawId || raw)
        };
    }

    // Pre-select on page load (re-display after validation failure)
    var preselected = hiddenEmpId.value;
    if (preselected && empMap[preselected]) selectEmployee(preselected);

    // ── Leave type change ──────────────────────────────────────────────────────
    window.onLeaveTypeChange = function (sel) {
        var id = sel.value;
        var lt = ltMap[id];
        if (!lt) {
            document.getElementById('ltInfo').style.display = 'none';
            currentAllowHalfDay = false;
            updateHalfDayPills();
            return;
        }
        currentAllowHalfDay = lt.allowHalfDay;
        document.getElementById('ltInfo').style.display  = 'block';
        document.getElementById('ltInfoText').textContent =
            lt.name + ' \u00b7 ' +
            (lt.max === 0 ? 'Unlimited days/yr' : 'Max ' + lt.max + ' days/yr') +
            (currentAllowHalfDay ? ' \u00b7 Half-day allowed' : ' \u00b7 Full-day only');
        updateHalfDayPills();
        recalcDays();
    };

    // ── Half-day pill enable / disable ────────────────────────────────────────
    function updateHalfDayPills() {
        var from = document.getElementById('fromDate').value;
        var to   = document.getElementById('toDate').value;
        var singleDay = (from && to && from === to);
        var canHalf   = currentAllowHalfDay && singleDay;
        var ltId = document.getElementById('leaveTypeId').value;

        ['pill-first', 'pill-second'].forEach(function (pid) {
            var pill  = document.getElementById(pid);
            var radio = pill.querySelector('input[type=radio]');
            if (canHalf) {
                pill.style.opacity       = '1';
                pill.style.pointerEvents = 'auto';
            } else {
                pill.style.opacity       = '0.4';
                pill.style.pointerEvents = 'none';
                if (!isInitialLoad && radio && radio.checked) {
                    document.querySelector('input[value="FullDay"]').checked = true;
                    onSessionChange(document.querySelector('input[value="FullDay"]'));
                }
            }
        });

        var notice = document.getElementById('halfdayNotice');
        if (ltId && !currentAllowHalfDay) {
            notice.textContent = '\u26A0 This leave type does not allow half-day applications.';
            notice.classList.add('show');
        } else if (currentAllowHalfDay && !singleDay && ltId) {
            notice.textContent = '\u26A0 Half-day is only available when From Date = To Date.';
            notice.classList.add('show');
        } else {
            notice.classList.remove('show');
        }
    }

    // ── Session pill active state ──────────────────────────────────────────────
    window.onSessionChange = function (radio) {
        document.querySelectorAll('.session-pill').forEach(function (p) {
            p.classList.remove('active');
        });
        if (radio && radio.parentElement)
            radio.parentElement.classList.add('active');
        recalcDays();
    };

    // ── Day count recalculation ────────────────────────────────────────────────
    window.recalcDays = function () {
        var from = document.getElementById('fromDate').value;
        var to   = document.getElementById('toDate').value;
        var dc   = document.getElementById('dayCount');
        if (!from || !to) { dc.style.display = 'none'; return; }
        var f = new Date(from), t = new Date(to);
        if (t < f) {
            document.getElementById('toDate').value = from;
            t = new Date(from);
        }
        var days    = Math.round((t - f) / 86400000) + 1;
        var session = document.querySelector('input[name="Form.Session"]:checked');
        var label   = days + ' day' + (days !== 1 ? 's' : '');
        if (session && days === 1 && session.value !== 'FullDay') label = '0.5 days';
        dc.style.display = 'inline-block';
        dc.textContent   = label;
        updateHalfDayPills();
    };

    // Init
    recalcDays();

    // Trigger leave type info display on re-render
    var ltSel = document.getElementById('leaveTypeId');
    if (ltSel && ltSel.value) onLeaveTypeChange(ltSel);

    ['fromDate', 'toDate'].forEach(function (id) {
        document.getElementById(id).addEventListener('change', recalcDays);
    });

    isInitialLoad = false;

}());
    </script>
}
