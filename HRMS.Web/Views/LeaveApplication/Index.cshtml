<div class="card">
    <div class="tbl-wrap">
        <table class="tbl">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Employee</th>
                    <th>Leave Type</th>
                    <th>From</th>
                    <th>To</th>
                    <th>Session</th>
                    <th style="text-align:center;">Days</th>
                    <th>Reason</th>
                    <th>Applied On</th>
                    <th>Status</th>
                    <th style="width:130px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="10" style="text-align:center;padding:48px;color:var(--muted);">
                            <div style="font-size:32px;margin-bottom:10px;opacity:.4;">&#128197;</div>
                            <div style="font-weight:600;margin-bottom:4px;color:var(--text);">
                                No leave applications found
                            </div>
                            <a href="@Url.Action("Apply")"
                               style="font-size:13px;color:var(--accent);">
                                Apply for Leave
                            </a>
                        </td>
                    </tr>
                }
                @foreach (var a in Model)
                {
                    string sessionLabel = a.Session == "FirstHalf" ? "First Half" :
                                         a.Session == "SecondHalf" ? "Second Half" : "Full Day";
                    string sessionIcon = a.Session == "FirstHalf" ? "&#9728;" :
                                         a.Session == "SecondHalf" ? "&#9790;" : "&#11835;";
                    <tr>
                        <td class="mono" style="color:var(--muted);font-size:12px;">
                            #@a.ApplicationId
                        </td>
                        <td>
                            <div style="font-weight:500;color:var(--text);">@a.EmployeeName</div>
                            <div class="mono" style="font-size:11px;color:var(--muted);">
                                @a.EmployeeId
                            </div>
                        </td>
                        <td>
                            <span class="dept-badge">@a.LeaveTypeMasterId</span>
                            <div style="font-size:11px;color:var(--muted);margin-top:2px;">
                                @a.LeaveTypeName
                            </div>
                        </td>
                        <td class="mono" style="font-size:12px;white-space:nowrap;">
                            @a.FromDate.ToString("dd MMM yyyy")
                        </td>
                        <td class="mono" style="font-size:12px;white-space:nowrap;">
                            @a.ToDate.ToString("dd MMM yyyy")
                        </td>
                        <td style="font-size:12px;white-space:nowrap;">
                            @Html.Raw(sessionIcon)&nbsp;@sessionLabel
                        </td>
                        <td class="mono" style="text-align:center;font-weight:600;">
                            @a.TotalDays
                        </td>
                        <td style="color:var(--muted);font-size:12px;max-width:160px;
                                   overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                            title="@a.Reason">
                            @a.Reason
                        </td>
                        <td style="font-size:12px;color:var(--muted);white-space:nowrap;">
                            @a.CreatedAt.ToString("dd MMM yyyy")
                        </td>
                        <td>
                            <span class="badge badge-@a.Status.ToLower()">@a.Status</span>
                        </td>
                        <td>
                            <div style="display:flex;gap:6px;">
                                @Html.ActionLink("Edit", "Edit", new { id = a.ApplicationId }, new { @class = "btn btn-sm btn-primary" })

                                @using (Html.BeginForm("Delete", "LeaveApplication", new { id = a.ApplicationId }, FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('Are you sure you want to delete this leave?');">
                                        Delete
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
