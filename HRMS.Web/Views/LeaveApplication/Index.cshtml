@model IEnumerable<HRMS.Application.DTOs.LeaveApplicationDto>
@using System.Linq
@{
    ViewBag.Title = "Leave Applications";
    Layout = "~/Views/Shared/_Layout.cshtml";

    int total = Model.Count();
    int pending = Model.Count(a => a.Status == "Pending");
    int approved = Model.Count(a => a.Status == "Approved");
    int rejected = Model.Count(a => a.Status == "Rejected");
}

<div class="page-header">
    <div>
        <div class="page-title">Leave Applications</div>
        <div class="page-sub">@total records</div>
    </div>
    <div style="display:flex;gap:8px;">
        @*@if (User.IsInRole("Admin") || User.IsInRole("HRManager"))
        {
            <a href="@Url.Action("Pending")" class="btn btn-ghost">
                &#9200;&nbsp;Pending (@pending)
            </a>
        }*@
        <a href="@Url.Action("Apply")" class="btn btn-primary">
            + Apply for Leave
        </a>
    </div>
</div>

<!-- Summary pills -->
@*@if (total > 0)
{
    <div style="display:flex;gap:10px;margin-bottom:18px;flex-wrap:wrap;">
        <span style="padding:4px 14px;border-radius:20px;font-size:12px;font-weight:600;
                     background:rgba(245,158,66,.12);color:#f59e42;border:1px solid rgba(245,158,66,.25);">
            &#9200; @pending Pending
        </span>
        <span style="padding:4px 14px;border-radius:20px;font-size:12px;font-weight:600;
                     background:rgba(52,211,153,.12);color:var(--accent2);border:1px solid rgba(52,211,153,.25);">
            &#10003; @approved Approved
        </span>
        <span style="padding:4px 14px;border-radius:20px;font-size:12px;font-weight:600;
