<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title – AMS</title>
    
    @Styles.Render("~/Content/layout")
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>
    <div class="app-shell">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sb-brand">
                <a href="@Url.Action("Index","Dashboard")" class="sb-logo">
                    <div class="sb-logo-icon">AMS</div>
                    <span class="sb-logo-text">AMS</span>
                </a>
            </div>
            <div class="sb-section">
                <div class="sb-section-label">Main</div>
                <a href="@Url.Action("Index","Dashboard")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="Dashboard"?"active":"")">
                    <span class="sb-icon">&#9732;</span> Dashboard
                </a>
                <a href="@Url.Action("Index","Employee")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="Employee"?"active":"")">
                    <span class="sb-icon">&#128100;</span> Employees
                </a>
            </div>
            <div class="sb-section">
                <div class="sb-section-label">Leave</div>
                <a href="@Url.Action("Index","LeaveApplication")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="Leave"?"active":"")">
                    <span class="sb-icon">&#128197;</span> Leave
                </a>
                <a href="@Url.Action("Apply","LeaveApplication")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="LeaveApplication"&&ViewContext.RouteData.Values["action"].ToString()=="Apply"?"active":"")">
                    <span class="sb-icon">&#128203;</span> Apply Leave
                </a>
                @*<a href="@Url.Action("Index","LeaveApplication")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="LeaveApplication"&&ViewContext.RouteData.Values["action"].ToString()=="Index"?"active":"")">
            <span class="sb-icon">&#128197;</span> My Applications
        </a>*@
            </div>
            @if (User.IsInRole("Admin") || User.IsInRole("HRManager"))
            {
                <div class="sb-section">
                    <div class="sb-section-label">Management</div>
                    <a href="@Url.Action("Index","ReportScreen")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="Report"?"active":"")">
                        <span class="sb-icon">&#128196;</span> Reports
                    </a>
                    @*<a href="@Url.Action("Pending","LeaveApplication")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="LeaveApplication"&&ViewContext.RouteData.Values["action"].ToString()=="Pending"?"active":"")">
                        <span class="sb-icon">&#9200;</span> Pending Approvals
                    </a>*@
                    <a href="@Url.Action("Index","LeaveTypeMaster")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="LeaveTypeMaster"?"active":"")">
                        <span class="sb-icon">&#9881;</span> Define Leave Types
                    </a>
                </div>
            }
            <div class="sb-footer">
                <div class="sb-user">
                    <div class="sb-avatar">@(User.Identity.IsAuthenticated ? User.Identity.Name.Substring(0, 1).ToUpper() : "?")</div>
                    <div class="sb-user-info">
                        <div class="name">@User.Identity.Name</div>
                        <div class="role">
                            @if (User.IsInRole("Admin"))
                            {<text>Administrator</text> }
                        else if (User.IsInRole("HRManager"))
                        { <text>HR Manager</text> }
                    else
                    { <text>Employee</text>}
                        </div>
                    </div>
                </div>
                @using (Html.BeginForm("Logout", "Account", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-logout" style="width:100%;margin-top:6px;">Sign Out</button>
                }
            </div>
        </aside>
        <!-- Main -->
        <div class="main-area">
            <div class="topbar">
                <span class="topbar-title">@ViewBag.Title</span>
                <div class="topbar-right">
                    <span style="font-size:12px;color:var(--muted);">@DateTime.Now.ToString("ddd, dd MMM yyyy")</span>
                </div>
            </div>
            <div class="page-body">
                @if (TempData["Success"] != null)
                {
                    <div class="toast toast-success">&#10003; @TempData["Success"]</div>
                }
                @if (TempData["Info"] != null)
                {
                    <div class="toast toast-info">&#8505; @TempData["Info"]</div>
                }
                @RenderBody()
            </div>
        </div>
    </div>
    <div class="theme-toggle">
        <input type="checkbox" id="themeToggle">
        <label for="themeToggle" class="toggle-track">
            <span class="toggle-thumb">
                <i id="themeIcon" class="bi bi-moon-fill"></i>
            </span>
        </label>
    </div>
    <script>
        // Auto-dismiss toasts
        setTimeout(() => document.querySelectorAll('.toast').forEach(t => t.remove()), 4000);

        //Session Idle Time Out CHecking
        setInterval(function () {
            fetch('/Account/CheckSession')
                .then(res => res.json())
                .then(data => {
                    if (!data.isActive) {
                        alert("Session expired. Please login again.");
                        window.location.href = "/Account/Login?sessionExpired=true";
                    }
                });
        }, 60000); // every 1 min

        //Theme Toggle
        const html = document.documentElement;
        const toggle = document.getElementById("themeToggle");
        const icon = document.getElementById("themeIcon");

        function applyTheme(theme) {
            html.setAttribute("data-theme", theme);

            // Sync toggle
            toggle.checked = theme === "dark";

            // FIX ICON LOGIC
            if (theme === "dark") {
                icon.className = "bi bi-moon-fill"; // 🌙
            } else {
                icon.className = "bi bi-sun-fill";  // ☀️
            }
        }

        const savedTheme = localStorage.getItem("theme") || "dark";
        applyTheme(savedTheme);

        toggle.addEventListener("change", function () {
            const newTheme = toggle.checked ? "dark" : "light";

            applyTheme(newTheme);
            localStorage.setItem("theme", newTheme);
        });
    </script>
    @Scripts.Render("~/bundles/jquery")
    @RenderSection("scripts", required: false)
</body>
</html>
