<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title – AMS</title>
    
    @Styles.Render("~/Content/layout")
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>
    <div class="app-shell">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sb-brand">
                <a href="@Url.Action("Index","Dashboard")" class="sb-logo">
                    <div class="sb-logo-icon">AMS</div>
                    <span class="sb-logo-text">AMS</span>
                </a>
            </div>
            <div class="sb-section">
                <div class="sb-section-label">Main</div>
                <a href="@Url.Action("Index","Dashboard")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="Dashboard"?"active":"")">
                    <span class="sb-icon">&#9732;</span> Dashboard
                </a>
                <a href="@Url.Action("Index","Employee")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="Employee"?"active":"")">
                    <span class="sb-icon">&#128100;</span> Employees
                </a>
            </div>
            <div class="sb-section">
                <div class="sb-section-label">Leave</div>
                <a href="@Url.Action("Index","LeaveTypeMaster")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="LeaveTypeMaster"?"active":"")">
                    <span class="sb-icon">&#9881;</span> Define Leave Types
                </a>
                <a href="@Url.Action("Index","LeaveApplication")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="Leave"?"active":"")">
                    <span class="sb-icon">&#128197;</span> Leave
                </a>
                <a href="@Url.Action("Apply","LeaveApplication")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="LeaveApplication"&&ViewContext.RouteData.Values["action"].ToString()=="Apply"?"active":"")">
                    <span class="sb-icon">&#128203;</span> Apply Leave
                </a>
                <a href="@Url.Action("Index","Holiday")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="Holiday"?"active":"")">
                    <span class="sb-icon">&#127881;</span> Holidays
                </a>
                @*<a href="@Url.Action("Index","LeaveApplication")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="LeaveApplication"&&ViewContext.RouteData.Values["action"].ToString()=="Index"?"active":"")">
            <span class="sb-icon">&#128197;</span> My Applications
        </a>*@
            </div>
            @if (User.IsInRole("Admin") || User.IsInRole("HRManager"))
            {
                <div class="sb-section">
                    <div class="sb-section-label">Management</div>
                    <a href="@Url.Action("Index","ReportScreen")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="Report"?"active":"")">
                        <span class="sb-icon">&#128196;</span> Reports
                    </a>
                    <a href="@Url.Action("Index","AttendanceTransaction")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="AttendanceTransaction"?"active":"")">
                        <span class="sb-icon">&#9201;</span> Attendance Transactions
                    </a>
                    <a href="@Url.Action("Index","TempCard")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="TempCard"?"active":"")">
                        <span class="sb-icon">&#128179;</span> Temp Cards
                    </a>
                    @*<a href="@Url.Action("Pending","LeaveApplication")" class="sb-link @(ViewContext.RouteData.Values["controller"].ToString()=="LeaveApplication"&&ViewContext.RouteData.Values["action"].ToString()=="Pending"?"active":"")">
            <span class="sb-icon">&#9200;</span> Pending Approvals
        </a>*@
                </div>
            }
            <div class="sb-footer">
                <div class="sb-user">
                    <div class="sb-avatar">@(User.Identity.IsAuthenticated ? User.Identity.Name.Substring(0, 1).ToUpper() : "?")</div>
                    <div class="sb-user-info">
                        <div class="name">@User.Identity.Name</div>
                        <div class="role">
                            @if (User.IsInRole("Admin"))
                            {<text>Administrator</text> }
                        else if (User.IsInRole("HRManager"))
                        { <text>HR Manager</text> }
                    else
                    { <text>Employee</text>}
                        </div>
                    </div>
                </div>
                @using (Html.BeginForm("Logout", "Account", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-logout" style="width:100%;margin-top:6px;">Sign Out</button>
                }
            </div>
        </aside>
        <!-- Main -->
        <div class="main-area">
            <div class="topbar">
                <span class="topbar-title">@ViewBag.Title</span>
                <div class="topbar-right">
                    <span style="font-size:12px;color:var(--muted);">@DateTime.Now.ToString("ddd, dd MMM yyyy")</span>
                </div>
            </div>
            <div class="page-body">
                @if (TempData["Success"] != null)
                {
                    <div class="toast toast-success">&#10003; @TempData["Success"]</div>
                }
                @if (TempData["Info"] != null)
                {
                    <div class="toast toast-info">&#8505; @TempData["Info"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="toast toast-error">&#9888; @TempData["Error"]</div>
                }
                @if (ViewData["UnhandledExceptionMessage"] != null)
                {
                    <div class="toast toast-error">&#9888; @ViewData["UnhandledExceptionMessage"]</div>
                }
                @RenderBody()
            </div>
        </div>
    </div>
    <div class="theme-toggle">
        <input type="checkbox" id="themeToggle">
        <label for="themeToggle" class="toggle-track">
            <span class="toggle-thumb">
                <i id="themeIcon" class="bi bi-moon-fill"></i>
            </span>
        </label>
    </div>
    <script>
        // Auto-dismiss toasts
        setTimeout(() => document.querySelectorAll('.toast').forEach(t => t.remove()), 4000);

        //Session Idle Time Out CHecking
        setInterval(function () {
            fetch('/Account/CheckSession')
                .then(res => res.json())
                .then(data => {
                    if (!data.isActive) {
                        alert("Session expired. Please login again.");
                        window.location.href = "/Account/Login?sessionExpired=true";
                    }
                });
        }, 60000); // every 1 min

        //Theme Toggle
        const html = document.documentElement;
        const toggle = document.getElementById("themeToggle");
        const icon = document.getElementById("themeIcon");

        function applyTheme(theme) {
            html.setAttribute("data-theme", theme);

            // Sync toggle
            toggle.checked = theme === "dark";

            // FIX ICON LOGIC
            if (theme === "dark") {
                icon.className = "bi bi-moon-fill"; // 🌙
            } else {
                icon.className = "bi bi-sun-fill";  // ☀️
            }
        }

        const savedTheme = localStorage.getItem("theme") || "dark";
        applyTheme(savedTheme);

        toggle.addEventListener("change", function () {
            const newTheme = toggle.checked ? "dark" : "light";

            applyTheme(newTheme);
            localStorage.setItem("theme", newTheme);
        });

        // Flexible date picker for every native date input in the app.
        (function () {
            var activePanel = null;
            var activeInput = null;
            var activeMonth = 0;
            var activeYear = 0;

            var monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun",
                "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
            var dayNames = ["Su", "Mo", "Tu", "We", "Th", "Fr", "Sa"];

            document.querySelectorAll('input[type="date"]').forEach(function (input) {
                enhanceDateInput(input);
            });

            document.addEventListener('click', function (evt) {
                if (!activePanel) return;
                if (activePanel.contains(evt.target) || evt.target === activeInput) return;
                if (evt.target.classList && evt.target.classList.contains('flex-date-btn')) return;
                closePanel();
            });

            window.addEventListener('resize', closePanel);
            window.addEventListener('scroll', closePanel, true);

            document.addEventListener('submit', function (evt) {
                var form = evt.target;
                if (!form || !form.querySelectorAll) return;
                form.querySelectorAll('input[data-flex-date="1"]').forEach(function (input) {
                    normalizeInput(input, false);
                });
            }, true);

            function enhanceDateInput(input) {
                if (input.dataset.flexDate === "1") return;

                input.dataset.flexDate = "1";
                input.dataset.dateValue = input.value || "";
                input.setAttribute("type", "text");
                input.setAttribute("autocomplete", "off");
                input.setAttribute("placeholder", "dd/mm/yyyy");

                var wrapper = document.createElement("div");
                wrapper.className = "flex-date-wrap";
                input.parentNode.insertBefore(wrapper, input);
                wrapper.appendChild(input);

                if (!input.disabled && !input.readOnly) {
                    var button = document.createElement("button");
                    button.type = "button";
                    button.className = "flex-date-btn";
                    button.title = "Open calendar";
                    button.setAttribute("aria-label", "Open calendar");
                    button.innerHTML = "&#128197;";
                    wrapper.appendChild(button);

                    button.addEventListener("click", function (evt) {
                        evt.preventDefault();
                        openPanel(input);
                    });
                }

                input.addEventListener("focus", function () {
                    if (!input.disabled && !input.readOnly) openPanel(input);
                });

                input.addEventListener("blur", function () {
                    normalizeInput(input, true);
                });

                input.addEventListener("keydown", function (evt) {
                    if (evt.key === "Enter") {
                        normalizeInput(input, true);
                        closePanel();
                    }
                    if (evt.key === "Escape") closePanel();
                });
            }

            function openPanel(input) {
                normalizeInput(input, false);
                activeInput = input;

                var selected = parseIso(input.value) || new Date();
                activeMonth = selected.getMonth();
                activeYear = selected.getFullYear();

                if (!activePanel) {
                    activePanel = document.createElement("div");
                    activePanel.className = "flex-date-panel";
                    document.body.appendChild(activePanel);
                }

                renderPanel();
                positionPanel();
            }

            function closePanel() {
                if (activePanel) activePanel.remove();
                activePanel = null;
                activeInput = null;
            }

            function positionPanel() {
                if (!activePanel || !activeInput) return;
                var rect = activeInput.getBoundingClientRect();
                var panelHeight = 330;
                var top = rect.bottom + 6;
                if (top + panelHeight > window.innerHeight) {
                    top = Math.max(8, rect.top - panelHeight - 6);
                }
                activePanel.style.left = Math.min(rect.left, window.innerWidth - 300) + "px";
                activePanel.style.top = top + "px";
            }

            function renderPanel() {
                if (!activePanel || !activeInput) return;

                activePanel.innerHTML = "";

                var head = document.createElement("div");
                head.className = "flex-date-head";

                var prev = document.createElement("button");
                prev.type = "button";
                prev.textContent = "<";
                prev.addEventListener("click", function () { shiftMonth(-1); });
                head.appendChild(prev);

                var month = document.createElement("select");
                monthNames.forEach(function (name, idx) {
                    var opt = document.createElement("option");
                    opt.value = idx;
                    opt.textContent = name;
                    if (idx === activeMonth) opt.selected = true;
                    month.appendChild(opt);
                });
                month.addEventListener("change", function () {
                    activeMonth = parseInt(this.value, 10);
                    renderPanel();
                });
                head.appendChild(month);

                var year = document.createElement("input");
                year.type = "number";
                year.min = "1900";
                year.max = "2100";
                year.value = activeYear;
                year.addEventListener("change", function () {
                    var val = parseInt(this.value, 10);
                    if (!isNaN(val)) activeYear = val;
                    renderPanel();
                });
                head.appendChild(year);

                var next = document.createElement("button");
                next.type = "button";
                next.textContent = ">";
                next.addEventListener("click", function () { shiftMonth(1); });
                head.appendChild(next);

                activePanel.appendChild(head);

                var grid = document.createElement("div");
                grid.className = "flex-date-grid";

                dayNames.forEach(function (name) {
                    var dow = document.createElement("div");
                    dow.className = "flex-date-dow";
                    dow.textContent = name;
                    grid.appendChild(dow);
                });

                buildDays(grid);
                activePanel.appendChild(grid);

                var actions = document.createElement("div");
                actions.className = "flex-date-actions";

                var today = document.createElement("button");
                today.type = "button";
                today.textContent = "Today";
                today.addEventListener("click", function () { chooseDate(new Date()); });
                actions.appendChild(today);

                var clear = document.createElement("button");
                clear.type = "button";
                clear.textContent = "Clear";
                clear.addEventListener("click", function () {
                    activeInput.value = "";
                    fireChange(activeInput);
                    closePanel();
                });
                actions.appendChild(clear);

                activePanel.appendChild(actions);
                positionPanel();
            }

            function buildDays(grid) {
                var first = new Date(activeYear, activeMonth, 1);
                var start = new Date(activeYear, activeMonth, 1 - first.getDay());
                var selected = parseIso(activeInput.value);
                var today = new Date();

                for (var i = 0; i < 42; i++) {
                    var date = new Date(start.getFullYear(), start.getMonth(), start.getDate() + i);
                    var btn = document.createElement("button");
                    btn.type = "button";
                    btn.className = "flex-date-day";
                    btn.textContent = date.getDate();

                    if (date.getMonth() !== activeMonth) btn.classList.add("muted");
                    if (sameDay(date, today)) btn.classList.add("today");
                    if (selected && sameDay(date, selected)) btn.classList.add("selected");

                    (function (d) {
                        btn.addEventListener("click", function () { chooseDate(d); });
                    }(date));

                    grid.appendChild(btn);
                }
            }

            function shiftMonth(delta) {
                var next = new Date(activeYear, activeMonth + delta, 1);
                activeMonth = next.getMonth();
                activeYear = next.getFullYear();
                renderPanel();
            }

            function chooseDate(date) {
                activeInput.value = toIso(date);
                fireChange(activeInput);
                closePanel();
            }

            function normalizeInput(input, fire) {
                if (!input.value) return true;

                var parsed = parseFlexibleDate(input.value);
                if (!parsed) return false;

                var iso = toIso(parsed);
                if (input.value !== iso) {
                    input.value = iso;
                    if (fire) fireChange(input);
                }
                return true;
            }

            function parseFlexibleDate(value) {
                var raw = (value || "").trim();
                if (!raw) return null;

                var lowered = raw.toLowerCase();
                if (lowered === "today") return new Date();

                var parts;
                if (/^\d{4}-\d{1,2}-\d{1,2}$/.test(raw)) {
                    parts = raw.split("-");
                    return makeDate(parts[0], parts[1], parts[2]);
                }

                if (/^\d{1,2}[\/\-. ]\d{1,2}[\/\-. ]\d{2,4}$/.test(raw)) {
                    parts = raw.split(/[\/\-. ]/);
                    return makeDate(normalizeYear(parts[2]), parts[1], parts[0]);
                }

                if (/^\d{8}$/.test(raw)) {
                    return makeDate(raw.substr(4, 4), raw.substr(2, 2), raw.substr(0, 2));
                }

                return null;
            }

            function parseIso(value) {
                if (!/^\d{4}-\d{2}-\d{2}$/.test(value || "")) return null;
                var parts = value.split("-");
                return makeDate(parts[0], parts[1], parts[2]);
            }

            function makeDate(year, month, day) {
                var y = parseInt(year, 10);
                var m = parseInt(month, 10);
                var d = parseInt(day, 10);
                if (isNaN(y) || isNaN(m) || isNaN(d)) return null;
                var date = new Date(y, m - 1, d);
                if (date.getFullYear() !== y || date.getMonth() !== m - 1 || date.getDate() !== d) return null;
                return date;
            }

            function normalizeYear(year) {
                if ((year || "").length !== 2) return year;
                var n = parseInt(year, 10);
                return (n >= 50 ? "19" : "20") + year;
            }

            function toIso(date) {
                var y = date.getFullYear();
                var m = String(date.getMonth() + 1).padStart(2, "0");
                var d = String(date.getDate()).padStart(2, "0");
                return y + "-" + m + "-" + d;
            }

            function sameDay(a, b) {
                return a.getFullYear() === b.getFullYear()
                    && a.getMonth() === b.getMonth()
                    && a.getDate() === b.getDate();
            }

            function fireChange(input) {
                input.dispatchEvent(new Event("input", { bubbles: true }));
                input.dispatchEvent(new Event("change", { bubbles: true }));
            }
        }());
    </script>
    @Scripts.Render("~/bundles/jquery")
    @RenderSection("scripts", required: false)
</body>
</html>
