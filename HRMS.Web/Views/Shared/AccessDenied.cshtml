@{
    ViewBag.Title = "Access Denied";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .denied-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 70vh;
        text-align: center;
        padding: 40px 20px;
    }

    .denied-icon-ring {
        position: relative;
        width: 110px;
        height: 110px;
        margin-bottom: 32px;
    }

    .denied-icon-ring::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 50%;
        border: 2px solid rgba(239,68,68,0.25);
        animation: pulse-ring 2s ease-out infinite;
    }

    .denied-icon-ring::after {
        content: '';
        position: absolute;
        inset: -14px;
        border-radius: 50%;
        border: 1.5px solid rgba(239,68,68,0.10);
        animation: pulse-ring 2s ease-out infinite 0.4s;
    }

    .denied-icon {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background: rgba(239,68,68,0.10);
        border: 1.5px solid rgba(239,68,68,0.30);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 44px;
        position: relative;
        z-index: 1;
    }

    @@keyframes pulse-ring {
        0%   { transform: scale(1);   opacity: 1; }
        100% { transform: scale(1.5); opacity: 0; }
    }

    .denied-code {
        font-family: 'DM Mono', monospace;
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: #ef4444;
        background: rgba(239,68,68,0.10);
        border: 1px solid rgba(239,68,68,0.25);
        padding: 5px 14px;
        border-radius: 20px;
        margin-bottom: 20px;
    }

    .denied-title {
        font-family: 'Syne', sans-serif;
        font-size: 32px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 12px;
        letter-spacing: -0.5px;
    }

    .denied-message {
        font-size: 14px;
        color: var(--muted);
        max-width: 420px;
        line-height: 1.7;
        margin-bottom: 36px;
    }

    .denied-actions {
        display: flex;
        gap: 12px;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
    }

    .denied-divider {
        width: 1px;
        height: 32px;
        background: var(--border);
        margin: 0 4px;
    }

    .denied-info {
        margin-top: 48px;
        padding: 18px 28px;
        background: rgba(91,110,245,0.06);
        border: 1px solid rgba(91,110,245,0.18);
        border-radius: 10px;
        max-width: 460px;
        text-align: left;
    }

    .denied-info-title {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        color: var(--accent);
        margin-bottom: 10px;
    }

    .denied-info ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 7px;
    }

    .denied-info ul li {
        font-size: 13px;
        color: var(--muted);
        display: flex;
        align-items: flex-start;
        gap: 8px;
        line-height: 1.5;
    }

    .denied-info ul li::before {
        content: '&#8250;';
        color: var(--accent);
        font-size: 16px;
        line-height: 1.3;
        flex-shrink: 0;
    }

    .denied-user-badge {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 5px 14px 5px 8px;
        font-size: 12px;
        color: var(--muted);
        margin-bottom: 24px;
    }

    .denied-user-avatar {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: rgba(91,110,245,0.2);
        color: var(--accent);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 700;
    }
</style>

<div class="denied-wrap">

    <!-- Animated lock icon -->
    <div class="denied-icon-ring">
        <div class="denied-icon">&#128274;</div>
    </div>

    <!-- Error code pill -->
    <div class="denied-code">403 &nbsp;&middot;&nbsp; Forbidden</div>

    <!-- Title -->
    <div class="denied-title">Access Denied</div>

    <!-- Signed-in user context -->
    @if (User.Identity.IsAuthenticated)
    {
        <div class="denied-user-badge">
            <div class="denied-user-avatar">
                @User.Identity.Name.Substring(0, 1).ToUpper()
            </div>
            Signed in as <strong style="color:var(--text);margin-left:2px;">@User.Identity.Name</strong>
        </div>
    }

    <!-- Message -->
    <p class="denied-message">
        You don&rsquo;t have the necessary permissions to view this page.
        If you think this is a mistake, please contact your system administrator
        or sign in with an account that has the required role.
    </p>

    <!-- Action buttons -->
    <div class="denied-actions">
        <a href="@Url.Action("Index", "Dashboard")" class="btn btn-primary">
            &#8592;&nbsp; Back to Dashboard
        </a>
        <div class="denied-divider"></div>
        @if (User.Identity.IsAuthenticated)
        {
            @using (Html.BeginForm("Logout", "Account", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-ghost">
                    Sign in as different user
                </button>
            }
        }
        else
        {
            <a href="@Url.Action("Login", "Account")" class="btn btn-ghost">
                Sign In
            </a>
        }
    </div>

    <!-- Role information box -->
    <div class="denied-info">
        <div class="denied-info-title">&#128274;&nbsp; Role Requirements</div>
        <ul>
            <li>This page requires <strong style="color:var(--text);">Admin</strong> or <strong style="color:var(--text);">HR Manager</strong> privileges.</li>
            <li>Your current role does not include access to this resource.</li>
            <li>Contact your administrator to request elevated access if needed.</li>
        </ul>
    </div>

</div>
