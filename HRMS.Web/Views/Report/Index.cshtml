@{
    ViewBag.Title = "Reports";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <div class="page-title">Crystal Reports</div>
        <div class="page-sub">Generate and export PDF reports</div>
    </div>
</div>

<div class="grid-3" style="align-items:start;">

    <!-- Employee Report -->
    <div class="card">
        <div class="card-header">
            <div style="font-size:28px;margin-bottom:10px;">&#128100;</div>
            <div class="card-title">Employee Report</div>
            <div class="card-sub">Full directory with salary details</div>
        </div>
        <div class="card-body">
            @using (Html.BeginForm("Employee","Report",FormMethod.Get,new{target="_blank"}))
            {
                <div class="form-group">
                    <label class="form-label">Department</label>
                    <select name="department" class="form-ctrl">
                        <option value="">All Departments</option>
                        @foreach (var d in new[]{"Engineering","HumanResources","Finance","Sales","Marketing","Operations"})
                        { <option value="@d">@d</option> }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-ctrl">
                        <option value="">All Status</option>
                        @foreach (var s in new[]{"Active","Inactive","OnLeave","Terminated"})
                        { <option value="@s">@s</option> }
                    </select>
                </div>
                <button type="submit" class="btn btn-primary" style="width:100%;">&#8599; Generate PDF</button>
            }
        </div>
    </div>

    <!-- Leave Report -->
    <div class="card">
        <div class="card-header">
            <div style="font-size:28px;margin-bottom:10px;">&#128197;</div>
            <div class="card-title">Leave Report</div>
            <div class="card-sub">All leave requests by date range</div>
        </div>
        <div class="card-body">
            @using (Html.BeginForm("Leave","Report",FormMethod.Get,new{target="_blank"}))
            {
                <div class="form-group">
                    <label class="form-label">From Date</label>
                    <input type="date" name="from" class="form-ctrl" value="@DateTime.Now.AddMonths(-1).ToString("yyyy-MM-dd")" />
                </div>
                <div class="form-group">
                    <label class="form-label">To Date</label>
                    <input type="date" name="to" class="form-ctrl" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>
                <button type="submit" class="btn btn-primary" style="width:100%;">&#8599; Generate PDF</button>
            }
        </div>
    </div>

    <!-- Payroll Report -->
    @if (User.IsInRole("Admin") || User.IsInRole("HRManager"))
    {
        <div class="card">
            <div class="card-header">
                <div style="font-size:28px;margin-bottom:10px;">&#128176;</div>
                <div class="card-title">Payroll Report</div>
                <div class="card-sub">Monthly salary & compensation summary</div>
            </div>
            <div class="card-body">
                @using (Html.BeginForm("Payroll","Report",FormMethod.Get,new{target="_blank"}))
                {
                    <div class="form-group">
                        <label class="form-label">Month</label>
                        <select name="month" class="form-ctrl">
                            @for (int m = 1; m <= 12; m++)
                            {
                                var selected = m == DateTime.Now.Month ? "selected" : "";
                                <option value="@m" @selected>@new DateTime(2000,m,1).ToString("MMMM")</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Year</label>
                        <select name="year" class="form-ctrl">
                            @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
                            { <option value="@y">@y</option> }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary" style="width:100%;">&#8599; Generate PDF</button>
                }
            </div>
        </div>
    }

</div>

<!-- Info Box -->
<div class="card mt-24" style="border-color:rgba(91,110,245,0.3);background:rgba(91,110,245,0.05);">
    <div class="card-body" style="display:flex;gap:16px;align-items:flex-start;">
        <div style="font-size:20px;margin-top:2px;">&#128161;</div>
        <div>
            <div style="font-weight:600;margin-bottom:6px;font-size:14px;">Crystal Report Setup Required</div>
            <div style="color:var(--muted);font-size:13px;line-height:1.7;">
                Place your <span class="mono" style="color:var(--accent);font-size:12px;">.rpt</span> files inside the
                <span class="mono" style="color:var(--accent);font-size:12px;">~/Reports/</span> folder:
                <code style="display:block;margin-top:8px;background:var(--bg);padding:10px 14px;border-radius:6px;font-size:12px;color:var(--accent2);">
                    Reports/<br>
                    &nbsp;&nbsp;EmployeeReport.rpt<br>
                    &nbsp;&nbsp;LeaveReport.rpt<br>
                    &nbsp;&nbsp;PayrollReport.rpt
                </code>
                Each <span class="mono" style="color:var(--accent);font-size:12px;">.rpt</span> must use the matching
                <span class="mono" style="color:var(--accent);font-size:12px;">EmployeeReportRow</span> /
                <span class="mono" style="color:var(--accent);font-size:12px;">LeaveReportRow</span> /
                <span class="mono" style="color:var(--accent);font-size:12px;">PayrollReportRow</span>
                class as its ADO.NET dataset source. See the Setup Guide for step-by-step instructions.
            </div>
        </div>
    </div>
</div>
