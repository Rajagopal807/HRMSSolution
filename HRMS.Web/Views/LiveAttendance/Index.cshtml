@{
    ViewBag.Title = "Live Attendance";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var realtimeUrl = ViewBag.RealtimeUrl as string ?? "";
    var resolveEmployeeUrl = Url.Action("ResolveEmployee", "LiveAttendance") ?? "";
}

<div class="page-header live-header">
    <div>
        <div class="page-title">Live Attendance</div>
        <div class="page-sub">Real-time biometric punches from AttendSync</div>
    </div>
    <div class="live-actions">
        <button type="button" class="btn btn-ghost" id="clearFeedBtn"><i class="bi bi-trash3"></i> Clear</button>
        <button type="button" class="btn btn-primary" id="reconnectBtn"><i class="bi bi-arrow-clockwise"></i> Reconnect</button>
    </div>
</div>

<div class="live-status-strip" data-state="connecting" id="connectionState">
    <div class="live-dot" aria-hidden="true"></div>
    <div>
        <div class="live-status-title" id="connectionTitle">Connecting</div>
        <div class="live-status-sub mono" id="streamUrl">@realtimeUrl</div>
    </div>
    <div class="live-status-time">
        <span>Last event</span>
        <strong id="lastEventTime">-</strong>
    </div>
</div>

<div class="kpi-grid live-kpis">
    <div class="kpi-card green">
        <div class="kpi-label">Punches Today</div>
        <div class="kpi-value" id="totalPunches">0</div>
        <div class="kpi-sub">Received in this browser session</div>
    </div>
    <div class="kpi-card blue">
        <div class="kpi-label">Unique Employees</div>
        <div class="kpi-value" id="uniqueEmployees">0</div>
        <div class="kpi-sub">Distinct employee IDs seen</div>
    </div>
    <div class="kpi-card orange">
        <div class="kpi-label">Last Direction</div>
        <div class="kpi-value live-direction" id="lastDirection">-</div>
        <div class="kpi-sub">Latest IN / OUT marker</div>
    </div>
</div>

<div class="live-grid">
    <section class="card live-last-card">
        <div class="card-header">
            <div class="card-title">Latest Punch</div>
            <div class="card-sub">Most recent event from StreamRealtime</div>
        </div>
        <div class="card-body">
            <div class="live-last-empty" id="latestEmpty">Waiting for a punch event</div>
            <div class="live-last" id="latestPunch" hidden>
                <div class="live-avatar" id="latestInitial">-</div>
                <div class="live-last-main">
                    <div class="live-emp mono" id="latestEmployee">-</div>
                    <div class="live-date" id="latestTimestamp">-</div>
                </div>
                <span class="live-pill" id="latestDirection">-</span>
            </div>
        </div>
    </section>

    <section class="card live-table-card">
        <div class="card-header">
            <div class="card-title">Punch Feed</div>
            <div class="card-sub">Newest events appear first</div>
        </div>
        <div class="tbl-wrap">
            <table class="tbl live-table">
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Punch ID</th>
                        <th>Employee Id</th>
                        <th>Employee Name</th>
                        <th>Direction</th>
                        <th>Received</th>
                    </tr>
                </thead>
                <tbody id="punchRows">
                    <tr id="emptyRow">
                        <td colspan="6" class="live-empty">No live punches received yet.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>
</div>

<style>
.live-header { gap:16px; }
.live-actions { display:flex;gap:8px;align-items:center; }
.live-status-strip { display:grid;grid-template-columns:auto 1fr auto;gap:14px;align-items:center;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:14px 16px;margin-bottom:16px; }
.live-dot { width:12px;height:12px;border-radius:50%;background:var(--accent3);box-shadow:0 0 0 5px rgba(245,158,66,.12); }
.live-status-strip[data-state="open"] .live-dot { background:var(--accent2);box-shadow:0 0 0 5px rgba(52,211,153,.12); }
.live-status-strip[data-state="error"] .live-dot { background:var(--danger);box-shadow:0 0 0 5px rgba(239,68,68,.12); }
.live-status-title { font-family:'Syne',sans-serif;font-weight:700;font-size:14px; }
.live-status-sub { color:var(--muted);font-size:12px;margin-top:2px;word-break:break-all; }
.live-status-time { text-align:right;color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.4px; }
.live-status-time strong { display:block;color:var(--text);font-size:13px;text-transform:none;letter-spacing:0;margin-top:3px; }
.live-kpis { margin-bottom:16px; }
.live-direction { font-size:28px; }
.live-grid { display:grid;grid-template-columns:minmax(260px,360px) 1fr;gap:16px;align-items:start; }
.live-last-card, .live-table-card { overflow:hidden;border-radius:8px; }
.live-last-empty, .live-empty { color:var(--muted);text-align:center;padding:34px 12px; }
.live-last { display:flex;align-items:center;gap:14px;min-height:88px; }
.live-avatar { width:56px;height:56px;border-radius:50%;display:grid;place-items:center;background:rgba(91,110,245,.16);border:1px solid rgba(91,110,245,.35);color:var(--accent);font-family:'Syne',sans-serif;font-weight:800;font-size:20px;flex:0 0 auto; }
.live-last-main { min-width:0;flex:1; }
.live-emp { font-size:20px;font-weight:700;color:var(--text);overflow-wrap:anywhere; }
.live-date { color:var(--muted);font-size:13px;margin-top:4px; }
.live-pill { display:inline-flex;align-items:center;justify-content:center;min-width:54px;border-radius:999px;padding:5px 12px;font-weight:700;font-size:12px;border:1px solid var(--border); }
.live-pill.in { background:rgba(52,211,153,.12);border-color:rgba(52,211,153,.35);color:var(--accent2); }
.live-pill.out { background:rgba(245,158,66,.12);border-color:rgba(245,158,66,.38);color:var(--accent3); }
.live-table td, .live-table th { white-space:nowrap; }
.live-new td { animation:liveFlash 1.2s ease; }
@@keyframes liveFlash { from { background:rgba(52,211,153,.14); } to { background:transparent; } }
@@media (max-width:980px) {
    .live-grid { grid-template-columns:1fr; }
    .live-status-strip { grid-template-columns:auto 1fr; }
    .live-status-time { grid-column:2;text-align:left; }
}
@@media (max-width:640px) {
    .live-header { align-items:flex-start;flex-direction:column; }
    .live-actions { width:100%; }
    .live-actions .btn { flex:1;justify-content:center; }
}
</style>

@section scripts {
    <script>
        (function () {
            var resolveEmployeeUrl = @Html.Raw(HttpUtility.JavaScriptStringEncode(resolveEmployeeUrl, true));
            var punches = [];
            var employees = {};
            var employeeLookupCache = {};
            var totalReceived = 0;
            var nextPunchId = 1;
            var maxRows = 100;
            var unsubscribe = null;

            var state = document.getElementById("connectionState");
            var title = document.getElementById("connectionTitle");
            var lastEventTime = document.getElementById("lastEventTime");
            var totalPunches = document.getElementById("totalPunches");
            var uniqueEmployees = document.getElementById("uniqueEmployees");
            var lastDirection = document.getElementById("lastDirection");
            var rows = document.getElementById("punchRows");
            var emptyRow = document.getElementById("emptyRow");
            var latestEmpty = document.getElementById("latestEmpty");
            var latestPunch = document.getElementById("latestPunch");
            var latestInitial = document.getElementById("latestInitial");
            var latestEmployee = document.getElementById("latestEmployee");
            var latestTimestamp = document.getElementById("latestTimestamp");
            var latestDirection = document.getElementById("latestDirection");

            document.getElementById("reconnectBtn").addEventListener("click", reconnect);
            document.getElementById("clearFeedBtn").addEventListener("click", clearFeed);

            // Mark this page as "currently viewing live attendance" so the
            // global topbar badge (in _Layout.cshtml) doesn't accumulate an
            // unseen-punch count while the user is already looking at it.
            document.body.classList.add("on-live-attendance-page");
            window.addEventListener("beforeunload", function () {
                document.body.classList.remove("on-live-attendance-page");
                if (unsubscribe) unsubscribe();
            });

            attachToGlobalFeed();

            function attachToGlobalFeed() {
                if (!window.LiveAttendanceFeed) {
                    // Global feed script (in the shared layout) hasn't initialized
                    // yet, or the user's role doesn't have it enabled. Retry briefly
                    // in case this fires before the layout script runs.
                    setStatus("error", "Live feed is not available");
                    setTimeout(function () {
                        if (window.LiveAttendanceFeed) attachToGlobalFeed();
                    }, 300);
                    return;
                }

                window.LiveAttendanceFeed.clearUnseen();
                setStatus(window.LiveAttendanceFeed.getState(), describeState(window.LiveAttendanceFeed.getState()));

                // Hydrate with whatever the global feed already buffered, in case
                // it received punches while the user was on a different page.
                var backlog = window.LiveAttendanceFeed.getBuffer();
                for (var i = backlog.length - 1; i >= 0; i--) {
                    addPunch(backlog[i], false);
                }

                var lastEventAt = window.LiveAttendanceFeed.getLastEventAt();
                if (lastEventAt) lastEventTime.textContent = formatTime(lastEventAt);

                unsubscribe = window.LiveAttendanceFeed.subscribe(function (evt) {
                    addPunch(evt, true);
                    setStatus("open", "Connected");
                });
            }

            function reconnect() {
                if (window.LiveAttendanceFeed) {
                    window.LiveAttendanceFeed.reconnect();
                    setStatus(window.LiveAttendanceFeed.getState(), describeState(window.LiveAttendanceFeed.getState()));
                }
            }

            function describeState(s) {
                return s === "open" ? "Connected" : s === "connecting" ? "Connecting" : "Connection interrupted";
            }

            function setStatus(kind, text) {
                state.setAttribute("data-state", kind);
                title.textContent = text;
            }

            function addPunch(evt, isLive) {
                var punch = normalizePunch(evt);
                totalReceived += 1;
                punches.unshift(punch);
                punches = punches.slice(0, maxRows);

                renderLatest(punch);
                renderTable();
                totalPunches.textContent = String(totalReceived);
                lastDirection.textContent = punch.direction || "-";
                if (isLive) lastEventTime.textContent = formatTime(new Date());

                resolvePunchEmployee(punch);
            }

            function normalizePunch(evt) {
                var tempCardId = evt.EmployeeId || evt.employeeId || "-";
                return {
                    id: nextPunchId++,
                    tempCardId: tempCardId,
                    employeeId: "",
                    employeeName: "Resolving...",
                    isResolved: false,
                    direction: (evt.Direction || evt.direction || "-").toUpperCase(),
                    timestamp: evt.Timestamp || evt.timestamp || null,
                    receivedAt: new Date()
                };
            }

            function renderLatest(punch) {
                latestEmpty.hidden = true;
                latestPunch.hidden = false;
                var label = punch.employeeName || punch.tempCardId || "-";
                latestInitial.textContent = label ? label.charAt(0).toUpperCase() : "-";
                latestEmployee.textContent = punch.employeeId
                    ? punch.employeeId + " - " + (punch.employeeName || "-")
                    : "Punch ID " + punch.tempCardId;
                latestTimestamp.textContent = formatDateTime(punch.timestamp);
                latestDirection.textContent = punch.direction;
                latestDirection.className = "live-pill " + (punch.direction === "IN" ? "in" : punch.direction === "OUT" ? "out" : "");
            }

            function renderTable() {
                rows.innerHTML = "";

                if (!punches.length) {
                    rows.appendChild(emptyRow);
                    return;
                }

                punches.forEach(function (punch, index) {
                    var tr = document.createElement("tr");
                    if (index === 0) tr.className = "live-new";
                    tr.innerHTML =
                        "<td class=\"mono\">" + escapeHtml(formatDateTime(punch.timestamp)) + "</td>" +
                        "<td class=\"mono\">" + escapeHtml(punch.tempCardId) + "</td>" +
                        "<td class=\"mono\">" + escapeHtml(punch.employeeId || "-") + "</td>" +
                        "<td>" + escapeHtml(punch.employeeName || (punch.isResolved ? "-" : "Resolving...")) + "</td>" +
                        "<td>" + renderDirection(punch.direction) + "</td>" +
                        "<td class=\"mono\">" + escapeHtml(formatTime(punch.receivedAt)) + "</td>";
                    rows.appendChild(tr);
                });
            }

            function resolvePunchEmployee(punch) {
                if (!resolveEmployeeUrl || !punch.tempCardId || punch.tempCardId === "-") {
                    markUnresolved(punch);
                    return;
                }

                var cacheKey = punch.tempCardId.toLowerCase();
                if (employeeLookupCache[cacheKey]) {
                    applyEmployeeLookup(punch, employeeLookupCache[cacheKey]);
                    return;
                }

                fetch(resolveEmployeeUrl + "?punchId=" + encodeURIComponent(punch.tempCardId), {
                    credentials: "same-origin",
                    headers: { "Accept": "application/json" }
                })
                    .then(function (response) {
                        if (!response.ok) throw new Error("Lookup failed");
                        return response.json();
                    })
                    .then(function (data) {
                        employeeLookupCache[cacheKey] = data;
                        applyEmployeeLookup(punch, data);
                    })
                    .catch(function () {
                        markUnresolved(punch);
                    });
            }

            function applyEmployeeLookup(punch, data) {
                punch.isResolved = true;
                punch.employeeId = data && data.found ? data.employeeId : "";
                punch.employeeName = data && data.found ? data.employeeName : "Punch ID not mapped";

                if (punch.employeeId) {
                    employees[punch.employeeId] = true;
                    uniqueEmployees.textContent = String(Object.keys(employees).length);
                }

                if (punches.length && punches[0].id === punch.id) renderLatest(punch);
                renderTable();
            }

            function markUnresolved(punch) {
                punch.isResolved = true;
                punch.employeeId = "";
                punch.employeeName = "Punch ID not mapped";
                if (punches.length && punches[0].id === punch.id) renderLatest(punch);
                renderTable();
            }

            function renderDirection(direction) {
                var css = direction === "IN" ? "in" : direction === "OUT" ? "out" : "";
                return "<span class=\"live-pill " + css + "\">" + escapeHtml(direction) + "</span>";
            }

            function clearFeed() {
                punches = [];
                employees = {};
                totalReceived = 0;
                totalPunches.textContent = "0";
                uniqueEmployees.textContent = "0";
                lastDirection.textContent = "-";
                lastEventTime.textContent = "-";
                latestPunch.hidden = true;
                latestEmpty.hidden = false;
                renderTable();
            }

            function formatDateTime(value) {
                if (!value) return "-";
                var date = new Date(value);
                if (isNaN(date.getTime())) return String(value);
                return date.toLocaleString([], { year: "numeric", month: "short", day: "2-digit", hour: "2-digit", minute: "2-digit", second: "2-digit" });
            }

            function formatTime(value) {
                var date = value instanceof Date ? value : new Date(value);
                if (isNaN(date.getTime())) return "-";
                return date.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit", second: "2-digit" });
            }

            function escapeHtml(value) {
                return String(value == null ? "" : value).replace(/[&<>"']/g, function (ch) {
                    return ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", "\"": "&quot;", "'": "&#39;" })[ch];
                });
            }
        }());
    </script>
}
