@{
    ViewBag.Title = "Attendance Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="page-header">
    <div>
        <div class="page-title">Attendance Register</div>
        <div class="page-sub">Generate monthly attendance report in PDF or Excel</div>
    </div>
</div>
@if (TempData["Error"] != null)
{
    <div style="background:#7f1d1d33;border:1px solid #b91c1c;border-radius:8px;
                padding:12px 16px;margin-bottom:20px;color:#fca5a5;font-size:13px;">
        &#9888;&nbsp;@TempData["Error"]
    </div>
}
<!-- ── Filter Card ────────────────────────────────────────────────────────── -->
<div class="card" style="max-width:640px;">
    <div class="card-header">
        <div class="card-title">Select Period</div>
        <div class="card-sub">Choose monthly or periodic dates for the attendance register</div>
    </div>
    <div class="card-body">
        <div class="form-group">
            <label class="form-label">Employee</label>
            <select id="employeeId" class="form-ctrl" style="max-width:100%;width:100%;">
                <option value="">All Employees</option>
                @foreach (var emp in (IEnumerable<SelectListItem>)ViewBag.Employees)
                {
                    <option value="@emp.Value">@emp.Text</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Duration</label>
            <div style="display:flex;gap:18px;flex-wrap:wrap;margin-top:8px;">
                <label style="display:flex;align-items:center;gap:8px;color:var(--text);font-size:13px;cursor:pointer;">
                    <input type="radio" name="durationMode" value="monthly" checked onchange="setDurationMode('monthly')" />
                    Monthly
                </label>
                <label style="display:flex;align-items:center;gap:8px;color:var(--text);font-size:13px;cursor:pointer;">
                    <input type="radio" name="durationMode" value="periodic" onchange="setDurationMode('periodic')" />
                    Periodic
                </label>
            </div>
        </div>
        <div id="monthFields" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;">
            <div class="form-group">
                <label class="form-label">Month</label>
                <select id="monthSelect" class="form-ctrl">
                    @for (int month = 1; month <= 12; month++)
                    {
                        var selected = month == DateTime.Now.Month ? "selected" : "";
                        <option value="@month" @selected>@(new DateTime(2000, month, 1).ToString("MMM"))</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Year</label>
                <select id="yearSelect" class="form-ctrl">
                    @for (int year = DateTime.Now.Year; year >= DateTime.Now.Year - 5; year--)
                    {
                        <option value="@year">@year</option>
                    }
                </select>
            </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;">
            <div class="form-group">
                <label class="form-label">From Date</label>
                <input type="date" id="fromDate" class="form-ctrl"
                       value="@ViewBag.FromDate" />
            </div>
            <div class="form-group">
                <label class="form-label">To Date</label>
                <input type="date" id="toDate" class="form-ctrl"
                       value="@ViewBag.ToDate" />
            </div>
        </div>
        <!-- Quick select buttons -->
        <div style="margin-bottom:20px;">
            <label class="form-label">Quick Select</label>
            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:6px;">
                <button type="button" class="btn btn-ghost btn-sm" onclick="setMonth(0)">This Month</button>
                <button type="button" class="btn btn-ghost btn-sm" onclick="setMonth(-1)">Last Month</button>
                <button type="button" class="btn btn-ghost btn-sm" onclick="setMonth(-2)">2 Months Ago</button>
                <button type="button" class="btn btn-ghost btn-sm" onclick="setMonth(-3)">3 Months Ago</button>
            </div>
        </div>
        <!-- Download buttons -->
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
            @if (User.IsInRole("Admin") || User.IsInRole("HRManager"))
            {
                <button type="button" class="btn btn-primary" onclick="download('pdf')">
                    &#128196;&nbsp;Download PDF
                </button>
                <button type="button" class="btn btn-success" onclick="download('excel')">
                    &#128202;&nbsp;Download Excel
                </button>
            }
            else
            {
                <div style="color:var(--muted);font-size:13px;padding:10px 0;">
                    &#128274;&nbsp;Report download requires Admin or HR Manager role.
                </div>
            }
        </div>
    </div>
</div>
<!-- ── Report Preview Info ────────────────────────────────────────────────── -->
