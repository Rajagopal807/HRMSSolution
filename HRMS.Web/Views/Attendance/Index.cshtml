@section scripts {
    <script>
(function () {

    function setMonth(offset) {
        var d    = new Date();
        var year = d.getFullYear();
        var mon  = d.getMonth() + offset;   // JS months 0-based

        // Normalise across year boundaries
        while (mon < 0)  { mon += 12; year--; }
        while (mon > 11) { mon -= 12; year++; }

        var firstDay = new Date(year, mon, 1);
        var lastDay  = new Date(year, mon + 1, 0);   // day 0 = last day of prev month

        document.getElementById('fromDate').value = fmt(firstDay);
        document.getElementById('toDate').value   = fmt(lastDay);
        document.getElementById('monthSelect').value = String(mon + 1);
        document.getElementById('yearSelect').value = String(year);
    }

    function setDurationMode(mode) {
        var isMonthly = mode === 'monthly';
        document.getElementById('monthFields').style.display = isMonthly ? 'grid' : 'none';

        if (isMonthly) {
            applySelectedMonth();
        }
    }

    function applySelectedMonth() {
        var month = parseInt(document.getElementById('monthSelect').value, 10);
        var year = parseInt(document.getElementById('yearSelect').value, 10);
        if (isNaN(month) || isNaN(year)) return;

        var firstDay = new Date(year, month - 1, 1);
        var lastDay = new Date(year, month, 0);

        document.getElementById('fromDate').value = fmt(firstDay);
        document.getElementById('toDate').value = fmt(lastDay);
    }

    function fmt(date) {
        var y  = date.getFullYear();
        var m  = String(date.getMonth() + 1).padStart(2, '0');
        var d  = String(date.getDate()).padStart(2, '0');
        return y + '-' + m + '-' + d;
    }

    function download(type) {
        var from = document.getElementById('fromDate').value;
        var to   = document.getElementById('toDate').value;
        var employeeId = document.getElementById('employeeId').value;

        if (!from || !to) {
            alert('Please select both From and To dates.');
            return;
        }
        if (from > to) {
            alert('From date cannot be after To date.');
            return;
        }

        var url = type === 'pdf' ? '@Url.Action("DownloadPdf", "Attendance")' : '@Url.Action("DownloadExcel", "Attendance")';
            url += '?from=' + from + '&to=' + to;
        if (employeeId) {
            url += '&employeeId=' + encodeURIComponent(employeeId);
        }

        if (window.showLoadingOverlay) window.showLoadingOverlay();
        window.location.href = url;
    }

    document.getElementById('monthSelect').addEventListener('change', applySelectedMonth);
    document.getElementById('yearSelect').addEventListener('change', applySelectedMonth);
    applySelectedMonth();

    // Expose to inline onclick
    window.setMonth   = setMonth;
    window.setDurationMode = setDurationMode;
    window.download   = download;

}());
    </script>
}
