@model HRMS.Web.ViewModels.ResetPasswordViewModel
@{
    Layout = null;
    ViewBag.Title = "Reset Password";
}

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>AMS – Reset Password</title>

    @Styles.Render("~/Content/css")
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>

<body>
    <div class="login-bg"></div>

    <div class="login-card">

        <div class="login-logo">
            <div class="logo-icon">AMS</div>
            <span class="logo-name">AMS Portal</span>
        </div>

        <h1>Reset Password</h1>
        <p class="sub">Enter your new password</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="err-box">
                @Html.ValidationSummary(true)
            </div>
        }

        @using (Html.BeginForm())
        {
            @Html.HiddenFor(m => m.Token)

            <!-- Password -->
            <div class="form-group">
                <label>New Password</label>

                <div class="input-wrapper">
                    @Html.PasswordFor(m => m.Password, new
                    {
                        @class = "form-input",
                        id = "passwordInput",
                        placeholder = "New Password"
                    })

                    <i class="bi bi-eye input-icon clickable" id="togglePassword"></i>
                </div>

                @Html.ValidationMessageFor(m => m.Password)
            </div>

            <!-- Confirm Password -->
            <div class="form-group">
                <label>Confirm Password</label>

                <div class="input-wrapper">
                    @Html.PasswordFor(m => m.ConfirmPassword, new
                    {
                        @class = "form-input",
                        placeholder = "Confirm Password"
                    })

                    <i class="bi bi-lock input-icon"></i>
                </div>

                @Html.ValidationMessageFor(m => m.ConfirmPassword)
            </div>

            <button type="submit" class="btn-login">
                Reset Password →
            </button>
        }

    </div>

    <div id="pageLoadingOverlay" class="page-loading-overlay" aria-live="polite" aria-busy="true" role="status">
        <div class="page-loading-card">
            <div class="page-loading-spinner" aria-hidden="true"></div>
            <div class="page-loading-title">Loading</div>
            <div class="page-loading-text">Please wait...</div>
        </div>
    </div>

    <!-- PASSWORD TOGGLE -->
    <script>
        (function () {
            var overlay = document.getElementById("pageLoadingOverlay");
            var hideTimer = null;

            function showLoadingOverlay() {
                if (!overlay) return;
                clearTimeout(hideTimer);
                overlay.classList.add("is-visible");
                document.body.classList.add("is-loading");
                hideTimer = setTimeout(hideLoadingOverlay, 30000);
            }

            function hideLoadingOverlay() {
                if (!overlay) return;
                clearTimeout(hideTimer);
                overlay.classList.remove("is-visible");
                document.body.classList.remove("is-loading");
            }

            window.addEventListener("pageshow", hideLoadingOverlay);
            window.addEventListener("load", hideLoadingOverlay);
            document.addEventListener("submit", function (evt) {
                setTimeout(function () {
                    if (!evt.defaultPrevented) showLoadingOverlay();
                }, 0);
            });
            window.addEventListener("beforeunload", showLoadingOverlay);
        }());

        const toggle = document.getElementById("togglePassword");
        const input = document.getElementById("passwordInput");

        toggle.addEventListener("click", function () {
            const isPassword = input.type === "password";

            input.type = isPassword ? "text" : "password";

            this.classList.toggle("bi-eye");
            this.classList.toggle("bi-eye-slash");
        });

        const html = document.documentElement;
        const toggleTheme = document.getElementById("themeToggle");
        const icon = document.getElementById("themeIcon");

        function applyTheme(theme) {
            html.setAttribute("data-theme", theme);

            if (!toggleTheme || !icon) return;

            if (theme === "dark") {
                toggleTheme.checked = true;
                icon.className = "bi bi-moon-fill";
            } else {
                toggleTheme.checked = false;
                icon.className = "bi bi-sun-fill";
            }
        }

        const savedTheme = localStorage.getItem("theme") || "dark";
        applyTheme(savedTheme);

        if (toggleTheme) {
            toggleTheme.addEventListener("change", function () {
                const newTheme = toggleTheme.checked ? "dark" : "light";

                applyTheme(newTheme);
                localStorage.setItem("theme", newTheme);
            });
        }

    </script>
</body>
</html>
