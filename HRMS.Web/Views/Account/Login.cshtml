@model HRMS.Web.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewBag.Title = "Sign In";
}
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>AMS – Sign In</title>
    @Styles.Render("~/Content/css")
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body>
    <div class="login-bg"></div>
    <div class="login-card">
        <div class="login-logo">
            <div class="logo-icon">AMS</div>
            <span class="logo-name">AMS Portal</span>
        </div>
        <h1>Welcome back</h1>
        <p class="sub">Sign in to access the Attendance Managment System(AMS) dashboard</p>
        @if (Request.QueryString["sessionExpired"] == "true")
        {
            <div class="err-box">
                Session expired due to inactivity. Please login again.
            </div>
        }
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""]?.Errors.Count > 0)
        {
            <div class="err-box">@Html.ValidationSummary(true)</div>
        }
        @using (Html.BeginForm("Login", "Account", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.Hidden("ReturnUrl", ViewBag.ReturnUrl as string)

            <div class="form-group full-width">
                @Html.LabelFor(m => m.Userid)
                <div class="input-wrapper">
                    @Html.TextBoxFor(m => m.Userid, new { @class = "form-input", placeholder = "User ID", autocomplete = "off" })
                    <i class="bi bi-person input-icon"></i>
                </div>
                @Html.ValidationMessageFor(m => m.Userid)
            </div>

            <div class="form-group full-width">
                @Html.LabelFor(m => m.Password)
                <div class="input-wrapper">
                    @Html.PasswordFor(m => m.Password, new { @class = "form-input", id = "passwordInput", placeholder = "Password", autocomplete = "new-password" })
                    <i class="bi bi-eye input-icon clickable" id="togglePassword"></i>
                </div>
                @Html.ValidationMessageFor(m => m.Password)
            </div>
            <div class="forgot-password">
                @Html.ActionLink("Forgot Password?", "ForgotPassword", "Account")
            </div>
            <button type="submit" class="btn-login">Sign In &rarr;</button>
        }
    </div>
    <div class="theme-toggle">
        <input type="checkbox" id="themeToggle">
        <label for="themeToggle" class="toggle-track">
            <span class="toggle-thumb">
                <i id="themeIcon" class="bi bi-moon-fill"></i>
            </span>
        </label>
    </div>
    <div id="pageLoadingOverlay" class="page-loading-overlay" aria-live="polite" aria-busy="true" role="status">
        <div class="page-loading-card">
            <div class="page-loading-spinner" aria-hidden="true"></div>
            <div class="page-loading-title">Loading</div>
            <div class="page-loading-text">Please wait...</div>
        </div>
    </div>
    <script>
        (function () {
            var overlay = document.getElementById("pageLoadingOverlay");
            var hideTimer = null;

            function showLoadingOverlay() {
                if (!overlay) return;
                clearTimeout(hideTimer);
                overlay.classList.add("is-visible");
                document.body.classList.add("is-loading");
                hideTimer = setTimeout(hideLoadingOverlay, 30000);
            }

            function hideLoadingOverlay() {
                if (!overlay) return;
                clearTimeout(hideTimer);
                overlay.classList.remove("is-visible");
                document.body.classList.remove("is-loading");
            }

            window.showLoadingOverlay = showLoadingOverlay;
            window.hideLoadingOverlay = hideLoadingOverlay;
            window.addEventListener("pageshow", hideLoadingOverlay);
            window.addEventListener("load", hideLoadingOverlay);

            document.addEventListener("submit", function (evt) {
                setTimeout(function () {
                    if (!evt.defaultPrevented) showLoadingOverlay();
                }, 0);
            });

            document.addEventListener("click", function (evt) {
                var link = evt.target.closest ? evt.target.closest("a[href]") : null;
                if (!link || evt.defaultPrevented || evt.button !== 0) return;
                if (link.target && link.target !== "_self") return;

                var url = new URL(link.href, window.location.href);
                if (url.origin === window.location.origin) {
                    setTimeout(showLoadingOverlay, 80);
                }
            });

            window.addEventListener("beforeunload", showLoadingOverlay);
        }());

        const html = document.documentElement;
        const toggle = document.getElementById("themeToggle");
        const icon = document.getElementById("themeIcon");

        function applyTheme(theme) {
            html.setAttribute("data-theme", theme);

            // Sync toggle
            toggle.checked = theme === "dark";

            // FIX ICON LOGIC
            if (theme === "dark") {
                icon.className = "bi bi-moon-fill"; // 🌙
            } else {
                icon.className = "bi bi-sun-fill";  // ☀️
            }
        }

        const savedTheme = localStorage.getItem("theme") || "dark";
        applyTheme(savedTheme);

        toggle.addEventListener("change", function () {
            const newTheme = toggle.checked ? "dark" : "light";

            applyTheme(newTheme);
            localStorage.setItem("theme", newTheme);
        });

        document.getElementById("togglePassword").addEventListener("click", function () {
            var password = document.getElementById("passwordInput");

            if (password.type === "password") {
                password.type = "text";
            } else {
                password.type = "password";
            }
        });
    </script>
    
</body>
</html>
