@model HRMS.Web.ViewModels.CreateEmployeeViewModel
@{
    /**/

    ViewBag.Title = "Add Employee";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<!-- ── Back ──────────────────────────────────────────────────────────────── -->
<div style="margin-bottom:20px;">
    <a href="@Url.Action("Index", "Employee")" class="btn btn-ghost btn-sm">
        &#8592;&nbsp;Back to Employees
    </a>
</div>
<!-- ── Page Header ───────────────────────────────────────────────────────── -->
<div class="page-header">
    <div>
        <div class="page-title">Add Employee</div>
        <div class="page-sub">Create a new employee record</div>
    </div>
</div>
@using (Html.BeginForm("Create", "Employee", FormMethod.Post, new { id = "employeeForm" }))
{
    @Html.AntiForgeryToken()

    <!-- Validation Summary -->
    if (!ViewData.ModelState.IsValid)
    {
        <div id="errordisplay" class="rpt-err-box">
            <strong>Please fix the following errors:</strong>
            @Html.ValidationSummary(true, "", new { style = "margin:6px 0 0;padding-left:16px;" })
        </div>
    }

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start;">
        <!-- ── Left: Personal Information ─────────────────────────────── -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">Personal Information</div>
                <div class="card-sub">Basic contact and identity details</div>
            </div>
            <div class="card-body">
                <!-- First Name + Last Name -->
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
                    <div class="form-group">
                        @Html.LabelFor(m => m.EmployeeID, "Employee ID *", new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.EmployeeID, new { @class = "form-ctrl", placeholder = "e.g. BD1001, 10001" })
                        @Html.ValidationMessageFor(m => m.EmployeeID, "",
                            new { @class = "err-label" })
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(m => m.EmployeeName, "Employee Name *", new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.EmployeeName, new { @class = "form-ctrl", placeholder = "e.g. Sharma" })
                        @Html.ValidationMessageFor(m => m.EmployeeName, "",
                            new { @class = "err-label" })
                    </div>
                </div>
                <!-- Email -->
                <div class="form-group">
                    @Html.LabelFor(m => m.Email, "Email Address", new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Email, new
                    {
                        @class = "form-ctrl",
                        type = "email",
                        placeholder = "arjun@company.com"
                    })
                    @Html.ValidationMessageFor(m => m.Email, "",
                        new { @class = "err-label" })
                </div>
                <!-- Phone -->
                <div class="form-group">
                    @Html.LabelFor(m => m.Phone, "Phone Number", new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Phone, new { @class = "form-ctrl", placeholder = "9876543210" })
                    @Html.ValidationMessageFor(m => m.Phone, "",
                        new { @class = "err-label" })
                </div>
                <!-- Date of Birth -->
                <div class="form-group">
                    @Html.LabelFor(m => m.DateOfBirth, "Date of Birth", new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.DateOfBirth, "{0:yyyy-MM-dd}",
                        new { @class = "form-ctrl", type = "date" })
                    @Html.ValidationMessageFor(m => m.DateOfBirth, "",
                        new { @class = "err-label" })
                </div>
                <!-- Address -->
                <div class="form-group">
                    @Html.LabelFor(m => m.Address, "Address", new { @class = "form-label" })
                    @Html.TextAreaFor(m => m.Address,
                        new { @class = "form-ctrl", rows = "3", placeholder = "Street, City, State" })
                </div>

                <div style="display:flex;align-items:center;justify-content:space-between;
                   padding:14px 16px;border-radius:8px;border:1px solid rgba(255,255,255,.08);
                   background:rgba(255,255,255,.03);margin-bottom:14px;">

                    <div style="display:flex;align-items:center;gap:12px;">
                        <span class="form-label">Gender</span>
                        <span id="genderBadge"></span>
                    </div>

                    @Html.HiddenFor(m => m.Gender, new { id = "GenderValue" })

                    <div class="gender-toggle" id="genderToggle">
                        <div class="gender-toggle-track"></div>
                        <div class="gender-toggle-thumb"></div>
                    </div>
                </div>

                <div style="display:flex;align-items:center;justify-content:space-between;
                    padding:14px 16px;border-radius:8px;border:1px solid rgba(255,255,255,.08);
                    background:rgba(255,255,255,.03);margin-bottom:14px;">

                    <div style="display:flex;align-items:center;gap:12px;">
                        <span class="form-label">Marital Status</span>
                        <span id="maritalBadge"></span>
                    </div>

                    @Html.HiddenFor(m => m.MaritalStatus, new { id = "MaritalValue" })

                    <div class="gender-toggle" id="maritalToggle">
                        <div class="gender-toggle-track"></div>
                        <div class="gender-toggle-thumb"></div>
                    </div>
                </div>
            </div>
        </div>
        <!-- ── Right: Job + Compensation ──────────────────────────────── -->
        <div style="display:flex;flex-direction:column;gap:16px;">
            <!-- Job Information -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title">Job Information</div>
                    <div class="card-sub">Role, department and joining details</div>
                </div>
                <div class="card-body">
                    <!-- Department -->
                    <div class="form-group">
                        @Html.LabelFor(m => m.Department, "Department *", new { @class = "form-label" })
                        @Html.DropDownListFor(m => m.Department,
                                Model.DepartmentOptions,
                                "-- Select Department --",
                                new { @class = "form-ctrl" })
                        @Html.ValidationMessageFor(m => m.Department, "",
                            new { @class = "err-label" })
                    </div>
                    <!-- Designation -->
                    <div class="form-group">
                        @Html.LabelFor(m => m.Designation, "Designation *", new { @class = "form-label" })
                        @Html.DropDownListFor(m => m.Designation,
                                Model.DesignationOptions,
                                "-- Select Designation --",
                                new { @class = "form-ctrl" })
                        @Html.ValidationMessageFor(m => m.Designation, "",
                            new { @class = "err-label" })
                    </div>
                    <!-- Joining Date -->
                    <div class="form-group">
                        @Html.LabelFor(m => m.JoiningDate, "Joining Date *", new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.JoiningDate, "{0:yyyy-MM-dd}",
                            new { @class = "form-ctrl", type = "date" })
                        @Html.ValidationMessageFor(m => m.JoiningDate, "",
                            new { @class = "err-label" })
                    </div>
                    <!-- Week Off 1 -->
                    <div class="form-group">
                        @Html.LabelFor(m => m.JoiningDate, "Week Off 1 *", new { @class = "form-label" })
                        @Html.DropDownListFor(m => m.WeekOff1,
                                Model.WeekOffOptions,
                                "-- Select Week Off 1 --",
                                new { @class = "form-ctrl" })
                        @Html.ValidationMessageFor(m => m.WeekOff1, "",
                            new { @class = "err-label" })
                    </div>
                    <!-- Week Off 2 -->
                    <div class="form-group">
                        @Html.LabelFor(m => m.JoiningDate, "Week Off 2 *", new { @class = "form-label" })
                        @Html.DropDownListFor(m => m.WeekOff2,
                                Model.WeekOffOptions,
                                "-- Select Week Off 2 --",
                                new { @class = "form-ctrl" })
                        @Html.ValidationMessageFor(m => m.WeekOff2, "",
                            new { @class = "err-label" })
                    </div>
                </div>
            </div>
            <!-- Form Actions -->
            <div style="display:flex;gap:10px;">
                <button type="submit" class="btn btn-primary" style="flex:1;">
                    &#10003;&nbsp;Create Employee
                </button>
                <a href="@Url.Action("Index", "Employee")" class="btn btn-ghost">
                    Cancel
                </a>
            </div>
        </div>
    </div>
}
@section scripts {

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var empInput = document.getElementById("EmployeeID");

            empInput.addEventListener("blur", function () {
                var value = empInput.value.trim();

                if (value !== "") {
                    empInput.value = value.padStart(11, '0'); // ✅ auto fill
                }
            });
        });

        /***************Gender ********************/
        const genderToggle = document.getElementById("genderToggle");
        const genderValue = document.getElementById("GenderValue");
        const genderBadge = document.getElementById("genderBadge");

        function normalizeGender(val) {
            if (!val) return "male";

            val = val.toString().toLowerCase();

            if (val === "0" || val === "female") return "female";
            return "male";
        }

        function initGender() {
            const normalized = normalizeGender(genderValue.value);

            if (normalized === "female") {
                setFemale();
            } else {
                setMale();
            }
        }

        function setMale() {
            genderValue.value = "1";
            genderToggle.classList.remove("female");
            genderToggle.classList.add("male");
            genderToggle.classList.remove("active");
            genderBadge.innerText = "Male";
            genderBadge.className = "badge badge-" + genderBadge.innerText.toLowerCase();
        }

        function setFemale() {
            genderValue.value = "0";
            genderToggle.classList.remove("male");
            genderToggle.classList.add("female");
            genderToggle.classList.add("active");
            genderBadge.innerText = "Female";
            genderBadge.className = "badge badge-" + genderBadge.innerText.toLowerCase();
        }

        genderToggle.addEventListener("click", () => {
            genderToggle.classList.toggle("active");

            if (genderToggle.classList.contains("active")) {
                setFemale();
            } else {
                setMale();
            }
        });

        initGender();

        /***************Marital Status ********************/
        const MaritalToggle = document.getElementById("maritalToggle");
        const maritalValue = document.getElementById("MaritalValue");
        const maritalBadge = document.getElementById("maritalBadge");

        function normalizeMarital(val) {
            if (!val) return "unmarried";

            val = val.toString().toLowerCase();

            if (val === "0" || val === "unmarried") return "unmarried";
            return "married";
        }

        function initMarital() {
            const normalized = normalizeMarital(maritalValue.value);

            if (normalized === "unmarried") {
                setUnmarried();
            } else {
                setMarried();
            }
        }

        function setMarried() {
            maritalValue.value = "1";
            MaritalToggle.classList.remove("umarried");
            MaritalToggle.classList.add("married");
            MaritalToggle.classList.remove("active");
            maritalBadge.innerText = "Married";
            maritalBadge.className = "badge badge-" + maritalBadge.innerText.toLowerCase();
        }

        function setUnmarried() {
            maritalValue.value = "0";
            MaritalToggle.classList.remove("married");
            MaritalToggle.classList.add("unmarried");
            MaritalToggle.classList.add("active");
            maritalBadge.innerText = "Unmarried";
            maritalBadge.className = "badge badge-" + maritalBadge.innerText.toLowerCase();
        }

        MaritalToggle.addEventListener("click", () => {
            MaritalToggle.classList.toggle("active");

            if (MaritalToggle.classList.contains("active")) {
                setUnmarried();
            } else {
                setMarried();
            }
        });

        initMarital();
    </script>
}
